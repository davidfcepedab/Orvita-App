# Copia a .env.local y rellena (no subas .env.local al repositorio).
# Clave en https://platform.openai.com/api-keys

# Desarrollo local sin login: el proxy no redirige a /auth (datos demo / localStorage según pantalla).
# NEXT_PUBLIC_APP_MODE=mock

# --- Apple (Password AutoFill / Universal Links / “Continuar con Apple”) ---
# AASA en `/.well-known/apple-app-site-association`: TeamID + bundle del target iOS, separados por coma.
# Ejemplo: ORVITA_APPLE_APP_IDS=ABCD123456.com.orvita.OrvitaMobile
# ORVITA_APPLE_APP_IDS=
#
# Botón “Continuar con Apple” en /auth (requiere proveedor Apple en Supabase + URL de retorno).
# NEXT_PUBLIC_AUTH_APPLE_SIGN_IN=1
#
# Botón “Continuar con Google” en /auth (proveedor Google en Supabase + URL de retorno /auth).
# NEXT_PUBLIC_AUTH_GOOGLE_SIGN_IN=1

# Generación de imagen objetivo (Entrenamiento) y resumen de salud con IA
OPENAI_API_KEY=

# Opcional: modelo del resumen de salud (por defecto gpt-4o-mini)
# OPENAI_HEALTH_SUMMARY_MODEL=gpt-4o-mini

# --- Web Push (notificaciones nativas) + bandeja in-app ---
# Generar: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:tu-correo@dominio.com
# Clave service_role: SUPABASE_SERVICE_ROLE_KEY o SUPABASE_SECRET_KEY (Vercel). Necesaria para registrar push.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# --- Cron / jobs automáticos (GET /api/cron/notifications/dispatch?jobs=...) ---
# Authorization: Bearer <CRON_SECRET> o cabecera x-reset-token: <INTERNAL_API_TOKEN>
# CRON_SECRET=
# INTERNAL_API_TOKEN=
# En local, si no defines ninguno de los dos, el guard permite la petición (solo desarrollo).

# Enlace "Compartir atajo" de iCloud (https://www.icloud.com/shortcuts/…). Activa "Instalar desde iCloud" en Config.
# Útil si `shortcuts sign` falla en el Mac. Opcional.
# NEXT_PUBLIC_ORVITA_HEALTH_SHORTCUT_ICLOUD_URL=

# --- Email (Resend) — digest matutino / semanal opcionales ---
# RESEND_API_KEY=
# EMAIL_FROM=Órvita <onboarding@resend.dev>
