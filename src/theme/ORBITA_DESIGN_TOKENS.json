{
  "meta": {
    "name": "Órbita OS Design System",
    "version": "3.0.0",
    "theme": "Arctic Zen",
    "defaultTheme": "arctic",
    "defaultBackground": "#F4F7F9",
    "description": "Sistema Operativo Personal Estratégico - Mobile First"
  },

  "colors": {
    "arctic": {
      "background": "#F4F7F9",
      "surface": "#FFFFFF",
      "surface-alt": "#EDF1F5",
      "border": "#E2E8F0",
      "text-primary": "#1E293B",
      "text-secondary": "#64748B",
      "accent-primary": "#6366F1",
      "accent-success": "#10B981",
      "accent-warning": "#F97316",
      "accent-danger": "#EF4444",
      "accent-health": "#10B981",
      "accent-finance": "#38BDF8",
      "accent-agenda": "#6366F1",
      "accent-training": "#10B981",
      "accent-habitos": "#818CF8"
    },
    "carbon": {
      "background": "#0F0F10",
      "surface": "#1A1A1B",
      "surface-alt": "#0F0F10",
      "border": "#262626",
      "text-primary": "#E5E5E5",
      "text-secondary": "#A3A3A3",
      "accent-primary": "#818CF8",
      "accent-success": "#34D399",
      "accent-warning": "#FBBF24",
      "accent-danger": "#F87171",
      "accent-health": "#34D399",
      "accent-finance": "#60A5FA",
      "accent-agenda": "#818CF8",
      "accent-training": "#34D399",
      "accent-habitos": "#818CF8"
    },
    "sand": {
      "background": "#FAF8F5",
      "surface": "#FFFCF7",
      "surface-alt": "#F5F1EA",
      "border": "#E8E2D8",
      "text-primary": "#292524",
      "text-secondary": "#78716C",
      "accent-primary": "#FCA5A5",
      "accent-success": "#FCD34D",
      "accent-warning": "#FDBA74",
      "accent-danger": "#FCA5A5",
      "accent-health": "#FCD34D",
      "accent-finance": "#FDBA74",
      "accent-agenda": "#FCA5A5",
      "accent-training": "#FCD34D",
      "accent-habitos": "#FCA5A5"
    }
  },

  "typography": {
    "font-family": {
      "base": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "ui-monospace, 'SF Mono', 'Cascadia Code', monospace"
    },
    "scale": {
      "h1": { "font-size": "32px", "font-weight": 500, "line-height": 1.5, "letter-spacing": "-0.02em" },
      "h2": { "font-size": "24px", "font-weight": 500, "line-height": 1.5, "letter-spacing": "-0.01em" },
      "h3": { "font-size": "20px", "font-weight": 500, "line-height": 1.5, "letter-spacing": "0" },
      "h4": { "font-size": "16px", "font-weight": 500, "line-height": 1.5, "letter-spacing": "0" },
      "body": { "font-size": "16px", "font-weight": 400, "line-height": 1.5, "letter-spacing": "0" },
      "body-sm": { "font-size": "14px", "font-weight": 400, "line-height": 1.5, "letter-spacing": "0" },
      "caption": { "font-size": "12px", "font-weight": 400, "line-height": 1.4, "letter-spacing": "0.01em" },
      "button": { "font-size": "16px", "font-weight": 500, "line-height": 1.5, "letter-spacing": "0" },
      "label": { "font-size": "16px", "font-weight": 500, "line-height": 1.5, "letter-spacing": "0" }
    }
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px",
    "3xl": "64px",
    "4xl": "96px"
  },

  "radius": {
    "card": "16px",
    "button": "10px",
    "input": "10px",
    "sm": "6px",
    "md": "8px",
    "lg": "10px",
    "xl": "16px",
    "2xl": "20px",
    "full": "9999px"
  },

  "elevation": {
    "card": "0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.02)",
    "hover": "0 4px 6px rgba(0,0,0,0.07), 0 2px 4px rgba(0,0,0,0.03)",
    "modal": "0 20px 25px rgba(0,0,0,0.1), 0 10px 10px rgba(0,0,0,0.04)",
    "arctic-soft": "0 2px 8px rgba(100,116,139,0.08)"
  },

  "layout": {
    "container-max-width": "1400px",
    "sidebar-width": "240px",
    "sidebar-collapsed-width": "64px",
    "header-height": "64px",
    "mobile-header-height": "56px",
    "grid-columns": { "mobile": 4, "tablet": 8, "desktop": 12 },
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },

  "border": {
    "width": { "default": "0.5px", "medium": "1px", "thick": "2px" },
    "style": "solid"
  },

  "animation": {
    "duration": { "fast": "150ms", "normal": "300ms", "slow": "500ms" },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "in-out": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },

  "semantic": {
    "status": {
      "success": "#10B981",
      "warning": "#F97316",
      "error": "#EF4444",
      "info": "#38BDF8",
      "neutral": "#64748B"
    },
    "priority": {
      "critical": "#EF4444",
      "high": "#F97316",
      "medium": "#FBBF24",
      "low": "#64748B"
    }
  }
}
